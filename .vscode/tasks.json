{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Go: Test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Go: Build",
      "type": "shell",
      "command": "go",
      "args": ["build", "./..."],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Go: Run",
      "type": "shell",
      "command": "go",
      "args": ["run", "."],
      "isBackground": true,
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "NPM: Test",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "cd web; npm run test"],
      "group": {
        "kind": "test"
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "NPM: Build",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "cd web; npm run build"],
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "NPM: Dev",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "cd web; npm run dev"],
      "isBackground": true,
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
