# Copy this file to .env and fill in the required values.
# Docker Compose automatically loads .env from the project root.

# ── Required ──────────────────────────────────────────────────────────────────
BITVAVO_API_KEY=your_api_key_here
BITVAVO_API_SECRET=your_api_secret_here

# ── Optional (defaults shown) ──────────────────────────────────────────────────
# KARASU_IMAGE_TAG=main    # pin to a version tag or short SHA for reproducible deploys
# PORT=8080
# KARASU_TELEGRAM_BOT_TOKEN=123456:your_bot_token
# KARASU_TELEGRAM_CHAT_ID=123456789
# KARASU_REFRESH_UNIVERSE_INTERVAL=15m
# KARASU_INGEST_TOP_INTERVAL=1m
# KARASU_INGEST_OTHER_INTERVAL=5m
# KARASU_GAP_REPAIR_INTERVAL=3m
# KARASU_INGEST_REPAIR_LOOKBACK=6h
# KARASU_BACKFILL_CHUNK=12h
